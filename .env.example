# AI Services
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Browser Configuration
BROWSER_HEADLESS=true
BROWSER_EXECUTABLE_PATH=
BROWSER_DATA_DIR=~/.openman/browser

# Permissions
PERMISSION_WEB_BROWSING=always
PERMISSION_WEB_FORMS=ask
PERMISSION_WEB_PAYMENTS=never
PERMISSION_LOCAL_READ=workspace
PERMISSION_LOCAL_WRITE=ask
PERMISSION_LOCAL_EXECUTE=sandboxed

# Server Configuration
PORT=3000
HOST=localhost

# Debug
DEBUG=false
VERBOSE=false
