{
  "name": "openman",
  "version": "0.1.0",
  "description": "Human-like AI companion with web browsing, AI services, and local tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openman": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "oxlint src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src"
  },
  "keywords": [
    "ai",
    "automation",
    "browser",
    "assistant",
    "web-automation",
    "ai-agent"
  ],
  "author": "OpenMan Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ne-man/openman.git"
  },
  "dependencies": {
    "puppeteer": "^22.0.0",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.15",
    "conf": "^12.0.0",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "oxlint": "^1.0.0",
    "oxfmt": "^0.35.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
