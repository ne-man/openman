#!/bin/bash

# OpenMan CLI 脚本
# 用法: openman [command]
# 命令:
#   build  - 编译 TypeScript 代码
#   run    - 启动 Web 服务
#   web    - 打开浏览器控制台网页
#   debug  - 编译 + 启动服务 + 打开控制台

set -e

# 加载 nvm 环境（如果存在）
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# 或者加载 fnm 环境（如果存在）
if [ -d "$HOME/.fnm" ]; then
    export PATH="$HOME/.fnm:$PATH"
    eval "$(fnm env --shell bash 2>/dev/null)" || true
fi

# 加载用户环境配置
if [ -f "$HOME/.bashrc" ]; then
    source "$HOME/.bashrc" 2>/dev/null || true
fi

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 项目根目录
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DIST_CLI="$PROJECT_DIR/dist/cli/index.js"
WEB_URL="http://localhost:3000"
PORT=3000

# 打印帮助信息
print_help() {
    echo -e "${CYAN}OpenMan - AI 助手命令行工具${NC}"
    echo ""
    echo "用法: openman <command> [options]"
    echo ""
    echo "命令:"
    echo -e "  ${GREEN}build${NC}   编译 TypeScript 代码"
    echo -e "  ${GREEN}run${NC}     启动 Web 服务"
    echo -e "  ${GREEN}web${NC}     打开浏览器控制台网页"
    echo -e "  ${GREEN}debug${NC}   编译 + 启动服务 + 打开控制台"
    echo -e "  ${GREEN}stop${NC}    停止运行中的服务"
    echo -e "  ${GREEN}status${NC}  查看服务状态"
    echo ""
    echo "示例:"
    echo "  openman build          # 编译项目"
    echo "  openman run            # 启动 Web 服务"
    echo "  openman web            # 打开浏览器控制台"
    echo "  openman debug          # 完整调试模式"
    echo ""
}

# 检查 Node.js 版本
check_node() {
    local node_version=$(node -v 2>/dev/null | cut -d'v' -f2 | cut -d'.' -f1)
    if [ -z "$node_version" ] || [ "$node_version" -lt 20 ]; then
        echo -e "${RED}错误: 需要 Node.js 20 或更高版本${NC}"
        echo "当前版本: $(node -v 2>/dev/null || echo '未安装')"
        exit 1
    fi
}

# 编译项目
build_project() {
    echo -e "${CYAN}🔨 编译 OpenMan...${NC}"
    cd "$PROJECT_DIR"
    
    if npm run build; then
        echo -e "${GREEN}✓ 编译成功${NC}"
    else
        echo -e "${RED}✗ 编译失败${NC}"
        exit 1
    fi
}

# 检查是否需要编译
check_build() {
    if [ ! -f "$DIST_CLI" ]; then
        echo -e "${YELLOW}未找到编译产物，正在编译...${NC}"
        build_project
    fi
}

# 运行 CLI
run_cli() {
    check_build
    cd "$PROJECT_DIR"
    node "$DIST_CLI" "$@"
}

# 检查端口是否被占用
check_port() {
    local port=$1
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        return 0  # 端口被占用
    else
        return 1  # 端口空闲
    fi
}

# 获取占用端口的 PID
get_port_pid() {
    local port=$1
    lsof -Pi :$port -sTCP:LISTEN -t 2>/dev/null | head -1
}

# 启动 Web 服务
start_web() {
    check_build
    
    # 检查端口
    if check_port $PORT; then
        echo -e "${YELLOW}端口 $PORT 已被占用${NC}"
        local pid=$(get_port_pid $PORT)
        if [ -n "$pid" ]; then
            echo -e "  PID: $pid"
            echo -n "是否停止现有服务? [y/N] "
            read -r answer
            if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
                kill $pid 2>/dev/null || true
                sleep 1
            else
                echo -e "${CYAN}Web 服务已在运行: $WEB_URL${NC}"
                return 0
            fi
        fi
    fi
    
    echo -e "${CYAN}🌐 启动 Web 服务...${NC}"
    cd "$PROJECT_DIR"
    
    # 后台启动服务
    nohup node "$DIST_CLI" start > "$PROJECT_DIR/.openman.log" 2>&1 &
    local pid=$!
    echo $pid > "$PROJECT_DIR/.openman.pid"
    
    # 等待服务启动
    echo -n "等待服务启动"
    local count=0
    while ! check_port $PORT && [ $count -lt 30 ]; do
        sleep 0.5
        echo -n "."
        ((count++))
    done
    echo ""
    
    if check_port $PORT; then
        echo -e "${GREEN}✓ Web 服务已启动 (PID: $pid)${NC}"
        echo -e "  ${CYAN}控制台: $WEB_URL${NC}"
        echo -e "  ${CYAN}WebSocket: ws://localhost:$((PORT + 1))${NC}"
        return 0
    else
        echo -e "${RED}✗ 服务启动失败${NC}"
        echo "查看日志: cat $PROJECT_DIR/.openman.log"
        return 1
    fi
}

# 打开浏览器
open_browser() {
    local url=$1
    echo -e "${CYAN}🌐 打开浏览器: $url${NC}"
    
    # 检测操作系统并打开浏览器
    if command -v xdg-open &> /dev/null; then
        xdg-open "$url" 2>/dev/null &
    elif command -v open &> /dev/null; then
        open "$url" 2>/dev/null &
    elif command -v gnome-open &> /dev/null; then
        gnome-open "$url" 2>/dev/null &
    else
        echo -e "${YELLOW}无法自动打开浏览器，请手动访问: $url${NC}"
    fi
}

# 启动 Web 并打开浏览器
start_web_and_open() {
    start_web
    sleep 1
    open_browser "$WEB_URL"
}

# 停止服务
stop_service() {
    local pid_file="$PROJECT_DIR/.openman.pid"
    
    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if kill -0 $pid 2>/dev/null; then
            echo -e "${CYAN}停止服务 (PID: $pid)...${NC}"
            kill $pid 2>/dev/null || true
            rm -f "$pid_file"
            echo -e "${GREEN}✓ 服务已停止${NC}"
        else
            echo -e "${YELLOW}服务未运行${NC}"
            rm -f "$pid_file"
        fi
    else
        # 检查端口
        if check_port $PORT; then
            local pid=$(get_port_pid $PORT)
            if [ -n "$pid" ]; then
                echo -e "${CYAN}发现运行中的服务 (PID: $pid)，正在停止...${NC}"
                kill $pid 2>/dev/null || true
                echo -e "${GREEN}✓ 服务已停止${NC}"
            fi
        else
            echo -e "${YELLOW}没有运行中的服务${NC}"
        fi
    fi
}

# 查看状态
show_status() {
    echo -e "${CYAN}📊 OpenMan 状态${NC}"
    echo ""
    
    # 检查编译状态
    if [ -f "$DIST_CLI" ]; then
        echo -e "  编译状态: ${GREEN}已编译${NC}"
    else
        echo -e "  编译状态: ${YELLOW}未编译${NC}"
    fi
    
    # 检查服务状态
    if check_port $PORT; then
        local pid=$(get_port_pid $PORT)
        echo -e "  Web 服务: ${GREEN}运行中${NC} (PID: $pid)"
        echo -e "  控制台: ${CYAN}$WEB_URL${NC}"
    else
        echo -e "  Web 服务: ${YELLOW}未运行${NC}"
    fi
    
    # Node 版本
    echo -e "  Node 版本: $(node -v 2>/dev/null || echo '未安装')"
    
    # 检查依赖
    if [ -d "$PROJECT_DIR/node_modules" ]; then
        echo -e "  依赖状态: ${GREEN}已安装${NC}"
    else
        echo -e "  依赖状态: ${YELLOW}未安装${NC} (运行 npm install)"
    fi
}

# Debug 模式：编译 + 运行 + 打开
debug_mode() {
    echo -e "${CYAN}🐛 Debug 模式${NC}"
    echo ""
    
    # 1. 编译
    build_project
    echo ""
    
    # 2. 启动服务
    start_web
    echo ""
    
    # 3. 打开浏览器
    sleep 1
    open_browser "$WEB_URL"
    
    echo ""
    echo -e "${GREEN}✓ Debug 模式启动完成${NC}"
    echo -e "  按 Ctrl+C 停止服务"
    echo ""
    
    # 保持脚本运行
    trap 'echo ""; stop_service; exit 0' INT TERM
    wait
}

# 主入口
main() {
    check_node
    
    case "${1:-}" in
        build)
            build_project
            ;;
        run)
            start_web
            ;;
        web)
            open_browser "$WEB_URL"
            ;;
        debug)
            debug_mode
            ;;
        stop)
            stop_service
            ;;
        status)
            show_status
            ;;
        help|--help|-h)
            print_help
            ;;
        cli)
            # 直接运行 CLI 命令
            shift
            run_cli "$@"
            ;;
        *)
            if [ -n "${1:-}" ]; then
                # 未知命令，传递给 CLI
                run_cli "$@"
            else
                print_help
            fi
            ;;
    esac
}

main "$@"
